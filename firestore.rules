rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { return id is string && id.size() <= 128; }
    function isSignedIn() { return true; } // For now, allowing anonymous for simplicity in this demo environment

    match /test/{id} {
      allow read: if true;
    }

    match /rooms/{roomId} {
      allow get: if true;
      allow create: if isValidId(roomId);
      allow update: if true; // Simple rules for demo
    }
  }
}
